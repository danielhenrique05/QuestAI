<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dungeon"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ===== CABEÇALHO ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="⚔"
            android:textSize="34sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="FORJADOR DE QUESTS"
            android:textColor="@color/flame_gold"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp"
            android:text="forje aventuras para sua mesa"
            android:textColor="@color/parchment_edge"
            android:textSize="13sp"
            android:fontFamily="serif"
            android:textStyle="italic" />

        <View
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/divider_ornate" />

        <!-- ===== CARD: ESCOLHA DO MODO ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_scroll"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📜 ESCOLHA SEU CAMINHO"
                android:textColor="@color/ink_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:letterSpacing="0.05"
                android:fontFamily="serif"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgModo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbAleatoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎲  Quest Aleatória — surpreenda-me"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:checked="true"
                    android:buttonTint="@color/ember_red"
                    android:paddingVertical="6dp" />

                <RadioButton
                    android:id="@+id/rbPersonalizada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✒️  Quest Personalizada — a partir da minha história"
                    android:textColor="@color/ink_dark"
                    android:textSize="14sp"
                    android:buttonTint="@color/arcane_purple"
                    android:paddingVertical="6dp" />
            </RadioGroup>
        </LinearLayout>

        <!-- ===== CARD: MODO ALEATÓRIO ===== -->
        <LinearLayout
            android:id="@+id/grupoAleatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_scroll"
            android:padding="18dp"
            android:layout_marginBottom="16dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 DETALHES DA AVENTURA"
                android:textColor="@color/ink_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ambientação"
                android:textColor="@color/ink_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spAmbientacao"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edittext_scroll"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dificuldade do grupo"
                android:textColor="@color/ink_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spDificuldade"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edittext_scroll" />
        </LinearLayout>

        <!-- ===== CARD: MODO PERSONALIZADO ===== -->
        <LinearLayout
            android:id="@+id/grupoPersonalizado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_scroll"
            android:padding="18dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔮 SUA HISTÓRIA"
                android:textColor="@color/ink_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contexto da campanha"
                android:textColor="@color/ink_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etContexto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:gravity="top|start"
                android:background="@drawable/edittext_scroll"
                android:hint="ex: o grupo acaba de chegar numa vila cercada por névoa..."
                android:textColorHint="#9C8A66"
                android:textColor="@color/ink_dark"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elementos a incluir"
                android:textColor="@color/ink_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etElementos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top|start"
                android:background="@drawable/edittext_scroll"
                android:hint="ex: elfo traidor, floresta amaldiçoada, espada perdida"
                android:textColorHint="#9C8A66"
                android:textColor="@color/ink_dark" />
        </LinearLayout>

        <!-- ===== BOTÃO DE AÇÃO ===== -->
        <Button
            android:id="@+id/btnGerar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/button_ember"
            android:text="⚔  FORJAR QUEST"
            android:textColor="@color/parchment"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:fontFamily="serif"
            android:elevation="4dp" />

        <TextView
            android:id="@+id/tvErro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text=""
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
