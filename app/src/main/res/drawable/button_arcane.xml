<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/arcane_purple_light"
                android:endColor="@color/arcane_purple" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/flame_gold" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/arcane_purple"
                android:endColor="#301B40" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/flame_gold" />
        </shape>
    </item>
</selector>
