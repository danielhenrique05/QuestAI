<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombra externa -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Borda dourada -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/parchment_edge" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Pergaminho -->
    <item
        android:bottom="7dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/parchment"
                android:endColor="@color/parchment_dark" />
            <corners android:radius="11dp" />
        </shape>
    </item>
</layer-list>
