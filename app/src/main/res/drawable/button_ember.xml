<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/ember_orange"
                android:endColor="@color/ember_red" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/flame_gold" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/ember_red"
                android:endColor="#5C1912" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/flame_gold" />
        </shape>
    </item>
</selector>
